mkdir -p "$(dirname "/boot/grub2/themes/avalanche/theme.txt")"
cat > "/boot/grub2/themes/avalanche/theme.txt" << 'TXTEOF'
# Avalanche OS GRUB theme
desktop-image: "background.png"
desktop-color: "#0A1628"
title-text: ""

+ boot_menu {
    left = 15%
    top = 28%
    width = 70%
    height = 44%
    item_color = "#C8D8E8"
    selected_item_color = "#FFFFFF"
    item_height = 28
    item_padding = 14
    item_spacing = 4
    scrollbar = false
}

+ label {
    left = 0
    top = 12%
    width = 100%
    align = "center"
    text = "Avalanche OS"
    color = "#E7EEF3"
}

+ label {
    id = "__timeout__"
    left = 0
    top = 76%
    width = 100%
    align = "center"
    color = "#6A8DA0"
    text = "Boot in %ds"
}
TXTEOF

# ── GRUB_THEME ───────────────────────────────────────────────────────────────
THEME_LINE='GRUB_THEME=/boot/grub2/themes/avalanche/theme.txt'
if grep -q '^GRUB_THEME=' "$GRUBDEF"; then
    sed -i "s|^GRUB_THEME=.*|$THEME_LINE|" "$GRUBDEF"
else
    echo "$THEME_LINE" >> "$GRUBDEF"
fi

echo "AVALANCHE: GRUB theme -> $THEME_LINE"
grep "^GRUB_DISTRIBUTOR=\|^GRUB_THEME=" "$GRUBDEF"

%end
