# avalanche-grub.ks — GENERATED by scripts/gen-grub-ks.py
# Do not edit by hand. Edit scripts/gen-grub-ks.py then re-run it.
#
# Sets GRUB_DISTRIBUTOR and installs a visual GRUB theme.
# Theme applies to INSTALLED systems (not the live ISO boot menu).

%post

# ── GRUB_DISTRIBUTOR ─────────────────────────────────────────────────────────
GRUBDEF=/etc/default/grub

if [ -f "$GRUBDEF" ]; then
    if grep -q '^GRUB_DISTRIBUTOR=' "$GRUBDEF"; then
        sed -i 's/^GRUB_DISTRIBUTOR=.*/GRUB_DISTRIBUTOR="Avalanche OS"/' "$GRUBDEF"
    else
        echo 'GRUB_DISTRIBUTOR="Avalanche OS"' >> "$GRUBDEF"
    fi
else
    echo 'GRUB_DISTRIBUTOR="Avalanche OS"' > "$GRUBDEF"
fi

# ── Visual theme ─────────────────────────────────────────────────────────────
mkdir -p /boot/grub2/themes/avalanche

