mkdir -p "$(dirname "/usr/share/wallpapers/AvalancheOS/metadata.json")"
cat > "/usr/share/wallpapers/AvalancheOS/metadata.json" << 'TXTEOF'
{
    "KPlugin": {
        "Id": "AvalancheOS",
        "Name": "Avalanche OS",
        "License": "CC-BY-SA-4.0",
        "Authors": [{ "Name": "Maxime Turcotte" }]
    }
}
TXTEOF

# ── Look-and-Feel package org.avalanche.desktop ───────────────────────────
mkdir -p "$(dirname "/usr/share/plasma/look-and-feel/org.avalanche.desktop/metadata.json")"
cat > "/usr/share/plasma/look-and-feel/org.avalanche.desktop/metadata.json" << 'TXTEOF'
{
    "KPackageStructure": "Plasma/LookAndFeel",
    "KPlugin": {
        "Id": "org.avalanche.desktop",
        "Name": "Avalanche OS",
        "Description": "Avalanche OS — backcountry splitboard touring theme",
        "License": "CC-BY-SA-4.0",
        "Authors": [{ "Name": "Maxime Turcotte" }],
        "EnabledByDefault": true
    }
}
TXTEOF

mkdir -p "$(dirname "/usr/share/plasma/look-and-feel/org.avalanche.desktop/contents/defaults")"
cat > "/usr/share/plasma/look-and-feel/org.avalanche.desktop/contents/defaults" << 'TXTEOF'
[kdeglobals][KDE]
widgetStyle=Breeze

[kdeglobals][General]
ColorScheme=AvalancheOS

[kdeglobals][Icons]
Theme=breeze-dark

[plasmarc][Theme]
name=breeze-dark

[Wallpaper]
Image=AvalancheOS

[kcminputrc][Mouse]
cursorTheme=breeze_cursors

[kwinrc][org.kde.kdecoration2]
library=org.kde.breeze
theme=Breeze

[KSplash]
Theme=org.kde.Breeze
TXTEOF

echo "AVALANCHE: look-and-feel installed (org.avalanche.desktop)"

# ── kdedefaults cascade (makes the theme the system default) ──────────────
mkdir -p "$(dirname "/etc/xdg/kdedefaults/package")"
cat > "/etc/xdg/kdedefaults/package" << 'TXTEOF'
org.avalanche.desktop
TXTEOF

mkdir -p "$(dirname "/etc/xdg/kdedefaults/kdeglobals")"
cat > "/etc/xdg/kdedefaults/kdeglobals" << 'TXTEOF'
[KDE]
LookAndFeelPackage=org.avalanche.desktop
widgetStyle=Breeze

[General]
ColorScheme=AvalancheOS

[Icons]
Theme=breeze-dark
TXTEOF

mkdir -p "$(dirname "/etc/xdg/kdedefaults/plasmarc")"
cat > "/etc/xdg/kdedefaults/plasmarc" << 'TXTEOF'
[Theme]
name=breeze-dark
TXTEOF

mkdir -p "$(dirname "/etc/xdg/kdedefaults/kwinrc")"
cat > "/etc/xdg/kdedefaults/kwinrc" << 'TXTEOF'
[org.kde.kdecoration2]
library=org.kde.breeze
theme=Breeze
TXTEOF

echo "AVALANCHE: kdedefaults cascade set (LookAndFeelPackage + ColorScheme)"

# ── Lockscreen wallpaper (system-wide default via /etc/xdg) ───────────────
mkdir -p "$(dirname "/etc/xdg/kscreenlockerrc")"
cat > "/etc/xdg/kscreenlockerrc" << 'TXTEOF'
[Greeter][Wallpaper][org.kde.image][General]
Image=file:///usr/share/wallpapers/AvalancheOS/
TXTEOF

# ── First-login autostart (apply LnF for installed users) ────────────────
mkdir -p "$(dirname "/etc/xdg/autostart/avalanche-firstlogin.desktop")"
cat > "/etc/xdg/autostart/avalanche-firstlogin.desktop" << 'TXTEOF'
[Desktop Entry]
Name=Avalanche OS First Login Setup
Exec=/usr/local/bin/avalanche-firstlogin
Type=Application
X-KDE-autostart-condition=avalanche-firstloginrc:General:done:false
TXTEOF

cat > /usr/local/bin/avalanche-firstlogin << 'EOF'
#!/bin/bash
# Runs once on first Plasma login for each user.
# Applies the Avalanche OS Look-and-Feel (wallpaper, colors, icons, deco).
plasma-apply-lookandfeel --apply org.avalanche.desktop
kwriteconfig6 --file avalanche-firstloginrc --group General --key done true
EOF
chmod +x /usr/local/bin/avalanche-firstlogin
echo "AVALANCHE: first-login autostart installed"

if file "/usr/share/wallpapers/AvalancheOS/contents/images/3840x2160.png" | grep -q "PNG image data"; then
    echo "AVALANCHE: wallpaper OK ($(wc -c < "/usr/share/wallpapers/AvalancheOS/contents/images/3840x2160.png") bytes)"
else
    echo "AVALANCHE ERROR: wallpaper is not a valid PNG!"
fi
if [ "$(cat /etc/xdg/kdedefaults/package)" = "org.avalanche.desktop" ] && [ -f "/usr/share/plasma/look-and-feel/org.avalanche.desktop/contents/defaults" ]; then
    echo "AVALANCHE: kdedefaults + look-and-feel verified"
else
    echo "AVALANCHE ERROR: kdedefaults/look-and-feel missing!"
fi
%end
